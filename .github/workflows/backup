            echo "======================================"
            echo "PASO 4: DEPENDENCIAS (SIN DEV)"
            echo "======================================"
            composer install --no-interaction --prefer-dist --optimize-autoloader --no-dev
            echo "✅ Dependencias instaladas (modo producción)"

            echo "======================================"
            echo "PASO 5: MIGRACIONES (MODO DESARROLLO)"
            echo "======================================"
            DB_HOST=$(grep "^DB_HOST=" .env | cut -d'=' -f2 | tr -d '\r')
            DB_PORT=$(grep "^DB_PORT=" .env | cut -d'=' -f2 | tr -d '\r')
            DB_NAME=$(grep "^DB_DATABASE=" .env | cut -d'=' -f2 | tr -d '\r')
            DB_USER=$(grep "^DB_USERNAME=" .env | cut -d'=' -f2 | tr -d '\r')
            DB_PASS=$(grep "^DB_PASSWORD=" .env | cut -d'=' -f2 | tr -d '\r')

            # Eliminar schemas custom SOLO si psql está disponible en el servidor.
            # || true evita que un fallo aquí aborte todo el deploy (set -e activo).
            if command -v psql &> /dev/null; then
              echo "→ Eliminando schemas custom en ${DB_NAME}..."
              PGPASSWORD="$DB_PASS" psql -h "$DB_HOST" -p "$DB_PORT" -U "$DB_USER" -d "$DB_NAME" \
                -c "DROP SCHEMA IF EXISTS ref CASCADE;" \
                -c "DROP SCHEMA IF EXISTS auth CASCADE;" \
                -c "DROP SCHEMA IF EXISTS core CASCADE;" \
                -c "DROP SCHEMA IF EXISTS academico CASCADE;" \
                -c "DROP SCHEMA IF EXISTS inscripcion CASCADE;" \
                -c "DROP SCHEMA IF EXISTS evaluacion CASCADE;" \
                -c "DROP SCHEMA IF EXISTS observador CASCADE;" \
                -c "DROP SCHEMA IF EXISTS mensajeria CASCADE;" \
                -c "DROP SCHEMA IF EXISTS notificacion CASCADE;" \
                -c "DROP SCHEMA IF EXISTS horario CASCADE;" \
                -c "DROP SCHEMA IF EXISTS auditoria CASCADE;" || true
              echo "✅ Schemas eliminados"
            else
              echo "⚠️  psql no encontrado — instalando postgresql-client..."
              apt-get install -y postgresql-client -qq > /dev/null 2>&1 || true
              # Intentar de nuevo si se pudo instalar
              if command -v psql &> /dev/null; then
                PGPASSWORD="$DB_PASS" psql -h "$DB_HOST" -p "$DB_PORT" -U "$DB_USER" -d "$DB_NAME" \
                  -c "DROP SCHEMA IF EXISTS ref CASCADE;" \
                  -c "DROP SCHEMA IF EXISTS auth CASCADE;" \
                  -c "DROP SCHEMA IF EXISTS core CASCADE;" \
                  -c "DROP SCHEMA IF EXISTS academico CASCADE;" \
                  -c "DROP SCHEMA IF EXISTS inscripcion CASCADE;" \
                  -c "DROP SCHEMA IF EXISTS evaluacion CASCADE;" \
                  -c "DROP SCHEMA IF EXISTS observador CASCADE;" \
                  -c "DROP SCHEMA IF EXISTS mensajeria CASCADE;" \
                  -c "DROP SCHEMA IF EXISTS notificacion CASCADE;" \
                  -c "DROP SCHEMA IF EXISTS horario CASCADE;" \
                  -c "DROP SCHEMA IF EXISTS auditoria CASCADE;" || true
                echo "✅ Schemas eliminados"
              else
                echo "⚠️  No se pudo instalar psql. Continuando — migrate:fresh puede fallar si hay tablas existentes."
              fi
            fi

            php artisan migrate:fresh --force --seed
            echo "✅ Base de datos recreada con migraciones y seeders"


