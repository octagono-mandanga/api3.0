####################################
# APP
####################################
APP_NAME=Octagono
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-api.octagono.app

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

####################################
# LOGS
####################################
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

####################################
# BASE DE DATOS (PostgreSQL)
####################################
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=octagono_db
DB_USERNAME=octagono_user
DB_PASSWORD=

####################################
# SESIONES & CACHÉ
# En producción usar 'file' o 'database' (sin Redis)
# Si tienes Redis disponible, cambia a 'redis'
####################################
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file

QUEUE_CONNECTION=database

####################################
# EMAIL — Resend
# Documentación: https://resend.com/docs/send-with-laravel
# 1. Crea una cuenta en resend.com
# 2. Verifica tu dominio (octagono.app)
# 3. Genera una API key
# MAIL_FROM_ADDRESS debe ser un correo del dominio verificado en Resend
####################################
MAIL_MAILER=resend
RESEND_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=verificacion@octagono.app
RESEND_FROM_NAME=Octágono

MAIL_FROM_ADDRESS=verificacion@octagono.app
MAIL_FROM_NAME=Octágono

# SSL — en producción debe ser true (dejar en true)
MAIL_VERIFY_SSL=true

####################################
# SMS — Twilio
# Documentación: https://www.twilio.com/docs/sms
# 1. Crea una cuenta en twilio.com
# 2. Obtén un número de teléfono Twilio
# 3. Copia el SID y Auth Token del dashboard
# TWILIO_FROM debe tener formato internacional: +15555555555
####################################
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+15555555555
TWILIO_BRAND_NAME=Octagono

####################################
# FRONTEND (CORS)
# URL del frontend que consumirá esta API
####################################
FRONTEND_URL=https://tu-app.octagono.app
SANCTUM_STATEFUL_DOMAINS=tu-app.octagono.app

####################################
# (NO REQUERIDO EN PRODUCCIÓN INICIAL)
# Redis, AWS, Broadcast — descomenta si los usas
####################################
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# BROADCAST_CONNECTION=log
# FILESYSTEM_DISK=local

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
